        <viewAttribute datatype="NVARCHAR" id="STOCK_STATUS" length="20"/>
        <viewAttribute datatype="DECIMAL" id="LABST" length="23" scale="3"/>
        <viewAttribute datatype="DECIMAL" id="EINME" length="23" scale="3"/>
