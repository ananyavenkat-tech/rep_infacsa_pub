      </viewAttributes>
      <calculatedViewAttributes/>
      <definition>
/********* Begin Procedure Script ************/
BEGIN
  var_out =
  WITH stock_base AS (
    SELECT
      MARD.WERKS,
      MARD.LGORT,
      MARD.MATNR,
      MARD.LABST,
      MARD.EINME
    FROM &quot;SLT_PRD_MM&quot;.&quot;MARD&quot; AS MARD
    WHERE MARD.LABST > 0 OR MARD.EINME > 0
  ),
  material_info AS (
    SELECT
      sb.WERKS,
      sb.LGORT,
      sb.MATNR,
      sb.LABST,
      sb.EINME,
      MARA.MEINS,
      MARA.MTYPE,
      MAKT.MAKTX,
      T001W.NAME1 AS PLANT_NAME,
      MBEW.STPRS * sb.LABST AS STOCK_VALUE,
      CASE
        WHEN sb.LABST = 0 THEN 'Out of Stock'
        WHEN sb.LABST &lt; 10 THEN 'Low Stock'
        ELSE 'In Stock'
      END AS STOCK_STATUS
    FROM stock_base AS sb
    LEFT JOIN &quot;SLT_PRD_MM&quot;.&quot;MARA&quot; AS MARA ON sb.MATNR = MARA.MATNR
    LEFT JOIN &quot;SLT_PRD_MM&quot;.&quot;MAKT&quot; AS MAKT ON sb.MATNR = MAKT.MATNR
    LEFT JOIN &quot;SLT_PRD_MM&quot;.&quot;T001W&quot; AS T001W ON sb.WERKS = T001W.WERKS
    LEFT JOIN &quot;SLT_PRD_MM&quot;.&quot;MBEW&quot; AS MBEW ON sb.MATNR = MBEW.MATNR AND sb.WERKS = MBEW.BWKEY
  )
  SELECT * FROM material_info;
END /********* End Procedure Script ************/
      </definition>
